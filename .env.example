APP_NAME=InvestNews
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Sao_Paulo

# Produção (HTTPS): use URL com esquema https para o @vite e asset() não gerarem http://
# APP_URL=https://seudominio.com.br
# Atrás de proxy reverso que repassa X-Forwarded-* (recomendado em produção)
# TRUSTED_PROXIES=*
# Força https na geração de URLs mesmo se APP_URL estiver errado (opcional)
# FORCE_HTTPS=true

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=investnews
DB_USERNAME=investnews
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

SANCTUM_STATEFUL_DOMAINS=localhost:8000,localhost:5173,127.0.0.1:8000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Use redis para filas assíncronas (ex.: contato). Em produção: php artisan horizon (ver serviço horizon no docker-compose)
QUEUE_CONNECTION=redis

# Laravel Horizon: quem pode acessar /horizon em produção (e-mails separados por vírgula). Em local, APP_ENV=local ignora a lista.
HORIZON_ALLOWED_EMAILS=

CACHE_STORE=database

# Redis (cache do NewsCache)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
NEWS_CACHE_STORE=redis
NEWS_CACHE_TTL=300

VITE_APP_NAME="${APP_NAME}"
